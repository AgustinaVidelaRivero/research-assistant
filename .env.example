# Azure OpenAI: API key (from Azure Portal → your resource → Keys and Endpoint)
AZURE_OPENAI_API_KEY=your-api-key-here

# Base URL of your Azure OpenAI resource (no path after the host)
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/

# API version for the REST/Azure OpenAI client (e.g. preview or stable date string)
AZURE_OPENAI_API_VERSION=2024-10-21

# Deployment names (one per model tier)
# These are the names YOU gave to your deployments in Azure, not the model names
AZURE_OPENAI_DEPLOYMENT_SIMPLE=gpt-4o-mini-deployment
AZURE_OPENAI_DEPLOYMENT_MEDIUM=gpt-4o-deployment
AZURE_OPENAI_DEPLOYMENT_COMPLEX=gpt-4o-deployment

# Optional: logging level (e.g. DEBUG, INFO, WARNING)
LOG_LEVEL=INFO
