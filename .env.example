# ──────────────────────────────────────────────────────────────────
# Azure OpenAI Configuration
# ──────────────────────────────────────────────────────────────────
# Get these values from your Azure OpenAI resource in the Azure portal:
# https://portal.azure.com → your resource → "Keys and Endpoint"

# API key (either Key 1 or Key 2 works)
AZURE_OPENAI_API_KEY=your-api-key-here

# Endpoint URL (must end with /)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# API version (latest stable as of April 2026)
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# ──────────────────────────────────────────────────────────────────
# Model deployments (tier-based routing for cost optimization)
# ──────────────────────────────────────────────────────────────────
# Each tier maps to an Azure deployment. MEDIUM and COMPLEX can point
# to the same deployment (e.g. gpt-4.1); the distinction is at the
# prompt/task level, not at the model level.

# SIMPLE: used by the Investigator (brainstorming subtopics)
# Recommended: gpt-4.1-mini (cheap, fast)
AZURE_OPENAI_DEPLOYMENT_SIMPLE=gpt-4.1-mini

# MEDIUM: used by the Curator (deep analytical synthesis)
# Recommended: gpt-4.1 (higher quality)
AZURE_OPENAI_DEPLOYMENT_MEDIUM=gpt-4.1

# COMPLEX: used by the Reporter (polished final output)
# Recommended: gpt-4.1 (same as MEDIUM, but can be upgraded to a stronger
# model like gpt-5 if available, without touching any code)
AZURE_OPENAI_DEPLOYMENT_COMPLEX=gpt-4.1
